PRIVATE_STOREFRONT_API_TOKEN=
PUBLIC_STORE_DOMAIN=f7vjea-hq.myshopify.com
PUBLIC_STOREFRONT_ID=
PUBLIC_CHECKOUT_DOMAIN=checkout.shopify.com
SESSION_SECRET=

# Shopify Admin (VAT relief + newsletter marketing — needs write_customers)
SHOPIFY_ADMIN_API_ACCESS_TOKEN=

# Deposit / pre-order setup (Dev Dashboard app — client credentials)
# Scopes: read_products, write_products, write_purchase_options
SHOPIFY_DEPOSIT_CLIENT_ID=
SHOPIFY_DEPOSIT_CLIENT_SECRET=

# Analytics & chat (Phase 8)
PUBLIC_GA4_ID=G-QMXNFNFTS0
# Numeric Shopify shop ID (meta.json → id). Used for Shopify Inbox on Hydrogen.
PUBLIC_SHOP_ID=90445414778

# Judge.me (Hydrogen / platform-independent widgets — Awesome plan)
# Docs: docs/rebuild/judgeme.md
JUDGEME_SHOP_DOMAIN=f7vjea-hq.myshopify.com
JUDGEME_PUBLIC_TOKEN=
